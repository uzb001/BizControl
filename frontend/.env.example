# ── API (build-time: used by Next.js rewrites for API proxy) ─────
# For local dev, leave as localhost. For Docker, set to http://backend:8080
BACKEND_URL=http://localhost:8080

# ── App ──────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=BizControl.uz
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── Optional: Analytics ─────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
